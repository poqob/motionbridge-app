import 'dart:convert';
import 'dart:io';
import 'dart:async';
import 'package:flutter/foundation.dart';

enum ConnectionState { disconnected, discovering, connected }

class NetworkManager {
  static final NetworkManager _instance = NetworkManager._internal();
  factory NetworkManager() => _instance;
  NetworkManager._internal();

  RawDatagramSocket? _socket;
  Timer? _discoveryTimer;

  // Bağlantı durumunu UI'ın dinleyebilmesi için bir Stream yapısı kuruyoruz
  final StreamController<ConnectionState> _connectionStateController =
      StreamController<ConnectionState>.broadcast();
  Stream<ConnectionState> get connectionStateStream =>
      _connectionStateController.stream;

  ConnectionState _currentState = ConnectionState.disconnected;

  // Host (Masaüstü) Bilgileri
  InternetAddress? _hostIp;
  int? _hostDataPort;
  String? _hostName;

  // Bilgileri saklamak için (SettingsProvider'dan eklenecek)
  String deviceName = "MotionBridge";
  String deviceId = "unknown";

  // Controller'ın dinleme portu
  final int localPort = 5000;

  // Data komutları için giden paket fonskiyonu
  void sendPacket(Map<String, dynamic> data) {
    if (_currentState != ConnectionState.connected ||
        _hostIp == null ||
        _hostDataPort == null ||
        _socket == null) {
      return; // Bağlı değilsek veri gönderme
    }

    try {
      final jsonString = jsonEncode(data);
      final bytes = utf8.encode(jsonString);
      _socket?.send(bytes, _hostIp!, _hostDataPort!);
    } catch (e) {
    }
  }

  void _setState(ConnectionState state) {
    _currentState = state;
    _connectionStateController.add(state);
  }

  /// Keşif yayınını (UDP Broadcast) başlatır
  Future<void> startDiscovery({
    required String name,
    required String id,
  }) async {
    deviceName = name;
    deviceId = id;

    if (_currentState != ConnectionState.disconnected) return;
    _setState(ConnectionState.discovering);

    try {
      // Dinleme ve gönderme işlemleri için soketi 5000 portuna bind ediyoruz.
      // Host bize bu porta cevap gönderecek.
      _socket = await RawDatagramSocket.bind(
        InternetAddress.anyIPv4,
        localPort,
      );
      _socket?.broadcastEnabled = true;


      // Cihazın yerel IP'sini bulalım
      String localIp = "127.0.0.1";
      final interfaces = await NetworkInterface.list(
        type: InternetAddressType.IPv4,
        includeLinkLocal: false,
      );
      for (var interface in interfaces) {
        for (var addr in interface.addresses) {
          if (!addr.isLoopback) {
            localIp = addr.address;
            break;
          }
        }
      }

      // Gelen onay (ACK) veya komut paketlerini dinleme kısmı
      _socket?.listen((RawSocketEvent event) {
        if (event == RawSocketEvent.read) {
          final datagram = _socket?.receive();
          if (datagram != null) {
            final msg = utf8.decode(datagram.data);
            _handleIncomingMessage(msg, datagram.address);
          }
        }
      });

      // Her 2 saniyede bir broadcast yayını at
      _discoveryTimer = Timer.periodic(const Duration(seconds: 2), (timer) {
        if (_currentState != ConnectionState.discovering) {
          timer.cancel();
          return;
        }

        final payload = {
          "type": "discovery",
          "id": deviceId,
          "name": deviceName,
          "role": "controller",
          "os": Platform.operatingSystem,
          "ip": localIp,
          "port": localPort, // Host'a "Bana bu porttan ulaş" diyoruz
          "version": 1,
        };

        final data = utf8.encode(jsonEncode(payload));
        // Hedef Masaüstü Dinleme Portu: 44444
        _socket?.send(data, InternetAddress("255.255.255.255"), 44444);
      });
    } catch (e) {
      stopDiscovery();
    }
  }

  /// Gelen cevapları işleme
  void _handleIncomingMessage(String msg, InternetAddress senderIp) {
    try {
      final json = jsonDecode(msg);

      // Eğer Host'tan onay (ACK) geldiyse
      if (json['type'] == 'discovery_ack' &&
          _currentState == ConnectionState.discovering) {
          "🤝 [Discovery] Handshake successful! Host: ${json['host_name']}",
        );

        // Host bilgilerini kaydet
        _hostIp = senderIp;
        _hostName = json['host_name'] ?? "Unknown Host";
        _hostDataPort = json['data_port'] ?? 44444;

        // Broadcastleri durdur, duruma 'connected' de
        _discoveryTimer?.cancel();
        _setState(ConnectionState.connected);
      }
      // Eğer Host bağlantıyı kestiğini bildirirse pinge veya dataya karşılık
      else if (json['type'] == 'disconnect') {
        disconnect();
      }
    } catch (e) {
        "⚠️ [NetworkManager] Unknown packet from ${senderIp.address}: $msg",
      );
    }
  }

  void disconnect() {
    _hostIp = null;
    _hostDataPort = null;
    _hostName = null;
    _setState(ConnectionState.disconnected);
    stopDiscovery();
  }

  void stopDiscovery() {
    _discoveryTimer?.cancel();
    _discoveryTimer = null;
    _socket?.close();
    _socket = null;
    _setState(ConnectionState.disconnected);
  }
}
